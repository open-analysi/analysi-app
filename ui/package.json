{
  "name": "@company/security-dashboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "preview": "vite preview",
    "test": "vitest",
    "test:once": "vitest run",
    "test:related": "vitest related --run --no-isolate",
    "test:coverage": "vitest run --coverage",
    "lint-staged": "lint-staged",
    "prepare": "husky install",
    "check": "npm run type-check && npm run lint -- --fix && npm run format && npm run test:once",
    "generate-mocks": "npx tsx scripts/generateMockData.ts",
    "test:integration": "./scripts/test-integration.sh",
    "test:integration:alerts": "npx tsx src/services/__tests__/testAlertsApi.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "demo": "playwright test --config demo/playwright.config.ts --headed",
    "demo:record": "playwright test --config demo/playwright.config.ts",
    "demo:mp4": "npm run demo:record && ffmpeg -i test-results/demo*/video.webm -c:v libx264 -crf 20 -preset slow -pix_fmt yuv420p -y demo/demo.mp4"
  },
  "dependencies": {
    "@axa-fr/react-oidc": "^7.26.7",
    "@headlessui/react": "^2.2.9",
    "@heroicons/react": "^2.2.0",
    "@hpcc-js/wasm": "^2.22.4",
    "@types/d3-graphviz": "^2.6.10",
    "@types/react-datepicker": "^6.2.0",
    "ace-builds": "^1.43.2",
    "axios": "^1.7.9",
    "cytoscape": "^3.31.2",
    "cytoscape-dagre": "^2.5.0",
    "d3-graphviz": "^5.6.0",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.4.7",
    "jsondiffpatch": "^0.7.3",
    "moment-timezone": "^0.6.0",
    "react": "^19.2.4",
    "react-ace": "^14.0.1",
    "react-datepicker": "^9.1.0",
    "react-dom": "^19.2.4",
    "react-json-pretty": "^2.2.0",
    "react-json-tree": "^0.20.0",
    "react-json-view-lite": "^2.4.2",
    "react-markdown": "^10.0.0",
    "react-resizable-panels": "^4.6.5",
    "react-router": "^7.13.0",
    "react-zoom-pan-pinch": "^3.7.0",
    "reaflow": "^5.4.1",
    "recharts": "^3.7.0",
    "styled-components": "^6.1.19",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@faker-js/faker": "^10.0.0",
    "@playwright/test": "^1.56.1",
    "@tailwindcss/postcss": "^4.2.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/ace": "^0.0.52",
    "@types/cytoscape": "^3.19.15",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/styled-components": "^5.1.34",
    "@types/testing-library__react": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.46.0",
    "@typescript-eslint/parser": "^8.46.0",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/coverage-v8": "^4.0.18",
    "baseline-browser-mapping": "^2.9.6",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-unicorn": "^63.0.0",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.2.4",
    "postcss": "^8.5.3",
    "prettier": "^3.5.1",
    "rollup-plugin-visualizer": "^7.0.0",
    "tailwindcss": "^4.2.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.9",
    "vitest": "^4.0.18"
  }
}
