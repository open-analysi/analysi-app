# API Configuration
VITE_API_URL=http://localhost:8080
VITE_API_TIMEOUT=5000

# Backend API Configuration
VITE_BACKEND_API_URL=http://localhost:8001

# Feature Flags
VITE_ENABLE_DEBUG_TOOLS=false

# E2E / dev API key — used by Playwright tests when VITE_DISABLE_AUTH=true.
# Must match ANALYSI_SYSTEM_API_KEY in the backend .env.
# VITE_E2E_API_KEY=dev-system-api-key-change-in-production

# Authentication (OIDC / Keycloak)
# Set the OIDC authority and client ID for your Keycloak realm
# VITE_OIDC_AUTHORITY=http://localhost:8080/realms/analysi
# VITE_OIDC_CLIENT_ID=analysi-app
# Set to 'true' to bypass OIDC authentication (for E2E tests or development)
# VITE_DISABLE_AUTH=true
