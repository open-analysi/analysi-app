{
  "name": "@analysi/cli",
  "version": "0.1.0",
  "description": "Analysi Security Platform CLI",
  "type": "module",
  "bin": {
    "analysi": "./bin/analysi"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "/bin",
    "/dist",
    "/cli-config.yaml",
    "/oclif.manifest.json"
  ],
  "scripts": {
    "build": "tsc -b",
    "dev": "node --loader ts-node/esm ./bin/dev.js",
    "generate": "node --loader ts-node/esm ./scripts/generate-commands.ts",
    "postpack": "rm -f oclif.manifest.json",
    "prepack": "npm run build && oclif manifest",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix"
  },
  "oclif": {
    "bin": "analysi",
    "dirname": "analysi",
    "commands": {
      "strategy": "pattern",
      "target": "./dist/commands"
    },
    "topicSeparator": " ",
    "topics": {
      "auth": {
        "description": "Authentication commands"
      },
      "config": {
        "description": "CLI configuration"
      },
      "alerts": {
        "description": "Manage security alerts"
      },
      "tasks": {
        "description": "Manage tasks"
      },
      "workflows": {
        "description": "Manage workflows"
      },
      "integrations": {
        "description": "Manage integrations"
      },
      "task-runs": {
        "description": "View task execution runs"
      },
      "workflow-runs": {
        "description": "View workflow execution runs"
      },
      "tools": {
        "description": "Discover Cy language tools"
      },
      "skills": {
        "description": "Manage skills (knowledge modules)"
      },
      "knowledge-units": {
        "description": "Manage knowledge units (tables, documents, indexes)"
      },
      "schedules": {
        "description": "Manage schedules"
      },
      "control-event-rules": {
        "description": "Manage control event rules"
      },
      "packs": {
        "description": "Manage content packs"
      },
      "platform": {
        "description": "Platform administration (requires platform_admin)"
      },
      "platform tenants": {
        "description": "Tenant lifecycle management"
      }
    },
    "plugins": [
      "@oclif/plugin-help",
      "@oclif/plugin-autocomplete"
    ]
  },
  "dependencies": {
    "@clack/prompts": "^0.10.0",
    "@oclif/core": "^4.2.0",
    "@oclif/plugin-autocomplete": "^3.2.0",
    "@oclif/plugin-help": "^6.2.0",
    "chalk": "^5.4.0",
    "cli-table3": "^0.6.5",
    "js-yaml": "^4.1.0",
    "ora": "^8.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.4",
    "oclif": "^4.17.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
