*.sublime-project
*.sublime-workspace

# Lab services (Splunk, LDAP, Echo EDR, Elasticsearch) moved to analysi-demo-loader/lab/

# External agents/skills are committed to git for easier deployment
# Use `make package-external-agents` and `make package-foundation-skills` to update them

# Terraform state — contains plaintext secrets, must never be committed
*.tfstate
*.tfstate.*
!*.tfstate.example
.terraform/
.terraform.lock.hcl

# SSH Deploy Keys and Private Keys (Project Milos - EC2 deployment)
# CRITICAL: Never commit private SSH keys or PEM files!
*.pem
# Ignore all files in deploy-keys directory
deployments/terraform/environments/ec2-demo/deploy-keys/*
# But allow .gitignore and .pub files (public keys are safe to commit)
!deployments/terraform/environments/ec2-demo/deploy-keys/.gitignore
!deployments/terraform/environments/ec2-demo/deploy-keys/*.pub

# AWS Troubleshooting Reports (generated by aws-troubleshooter agent)
AWS_TROUBLESHOOTING_REPORT.md
AWS_TROUBLESHOOTING_REPORT_*.md

# Helm chart dependencies (fetched via helm dependency build)
deployments/helm/*/charts/
deployments/helm/*/Chart.lock

# Playwright
.playwright-mcp/
