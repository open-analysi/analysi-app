# Test environment configuration (shared defaults).
# Branch-specific overrides are in .env.test.local (auto-generated by `make test-db-up`).
# Do NOT edit this file for branch-specific settings.

# PostgreSQL Test Database Configuration (matches docker-compose settings)
TEST_DB_HOST=localhost
TEST_DB_PORT=5434
TEST_DB_USER=dev
TEST_DB_PASSWORD=devpassword
TEST_DB_NAME=analysi_test

# Database URL for workers (used by alert analysis worker)
DATABASE_URL=postgresql+asyncpg://dev:devpassword@localhost:5434/analysi_test

# Use PostgreSQL for all tests (SQLite no longer supported)
USE_POSTGRES_TESTS=true

# Test Configuration
PYTEST_TIMEOUT=300
PYTEST_MAXFAIL=10

# MinIO Configuration for testing
MINIO_ROOT_USER=analysi-minio-dev-user
MINIO_ROOT_PASSWORD=analysi-minio-dev-password
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=analysi-minio-dev-user
MINIO_SECRET_KEY=analysi-minio-dev-password
MINIO_BUCKET=analysi-storage-test
ARTIFACTS_BUCKET=analysi-storage-test

# Valkey/Redis Configuration for testing
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_DB=100
VALKEY_PASSWORD=analysi-valkey-dev-password

# Valkey Database Allocation (Testing: 100+)
VALKEY_TEST_ALERT_PROCESSING_DB=100
VALKEY_TEST_DATA_INGESTION_DB=101
VALKEY_TEST_AUTOMATION_DB=102
VALKEY_TEST_SCHEDULING_DB=103
VALKEY_TEST_CACHE_DB=104
VALKEY_TEST_ISOLATED_DB=110

# Alert Worker Configuration for testing
# ALERT_WORKER_TIMEOUT must be > 300 (WORKFLOW_EXECUTION_POLL_TIMEOUT = TIMEOUT - 300)
# Values ≤ 300 make poll timeout zero, breaking the tenacity decorator at import time.
ALERT_WORKER_PROCESSES=1
ALERT_WORKER_MAX_JOBS=5
ALERT_WORKER_TIMEOUT=900

# Backend API Configuration for Tests (external access from host machine)
BACKEND_API_HOST=localhost
BACKEND_API_PORT=8001
BACKEND_API_EXTERNAL_PORT=8001
BACKEND_API_AUTH_TOKEN=test-token-123

# Integration Worker Configuration for testing
VALKEY_EXTERNAL_PORT=6380
INTEGRATION_REDIS_HOST=localhost
INTEGRATION_REDIS_PORT=6380
INTEGRATION_REDIS_DB=1
INTEGRATION_MAX_JOBS=5
INTEGRATION_JOB_TIMEOUT=300
INTEGRATION_POLL_INTERVAL=30
INTEGRATION_PULL_LOOKBACK=120
INTEGRATION_DEFAULT_TENANT=default
# Disable ARQ cron jobs during tests to prevent interference
DISABLE_INTEGRATION_WORKER=true

# Integration Reconciliation Settings for testing
INTEGRATION_RECONCILE_INTERVAL=60
INTEGRATION_RECONCILE_LOCK_TTL=10

# Splunk Integration Test Configuration (defaults for unit test mocks — no live connection)
SPLUNK_HOST=localhost
SPLUNK_PORT=8089
SPLUNK_USERNAME=admin
SPLUNK_PASSWORD=changeme123
SPLUNK_SEARCH_QUERY=search index=notable | head 10

# Echo EDR Server Configuration for Tests (defaults for unit test mocks — no live connection)
ECHO_SERVER_HOST=localhost
ECHO_SERVER_PORT=8003
ECHO_SERVER_EXTERNAL_PORT=8003

# Vault Configuration for Tests (external access from host machine)
VAULT_HOST=localhost
VAULT_PORT=8200
VAULT_EXTERNAL_PORT=8200
VAULT_TOKEN=dev-root-token
VAULT_DEV_ROOT_TOKEN=dev-root-token
VAULT_LOG_LEVEL=info
VAULT_KEY_PREFIX=test  # Use test- prefix for test keys

# Third-Party Integration API Keys for Testing
# REQUIRED for integration tests - tests will FAIL if not provided
# Get free API keys from the respective services:
# - AbuseIPDB: https://www.abuseipdb.com/ (1,000 requests/day free) - REQUIRED
# - VirusTotal: https://www.virustotal.com/ (500 requests/day free) - Optional
ABUSEIPDB_API_KEY=
VIRUSTOTAL_API_KEY=
