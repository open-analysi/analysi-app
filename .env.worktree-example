# Worktree Environment — Port Offsets for Second Instance
#
# Copy to .env in your worktree directory and adjust as needed.
# All external ports are offset by +10 to avoid conflicts with the primary instance.
#
# Usage:
#   git worktree add ../analysi-app-wt2
#   cp .env.worktree-example ../analysi-app-wt2/.env
#   cd ../analysi-app-wt2 && make up

# PostgreSQL
POSTGRES_EXTERNAL_PORT=5444

# API
API_EXTERNAL_PORT=8011

# MinIO
MINIO_EXTERNAL_PORT=9010
MINIO_CONSOLE_EXTERNAL_PORT=9011

# Valkey
VALKEY_EXTERNAL_PORT=6390

# Keycloak
KEYCLOAK_EXTERNAL_PORT=8090

# UI
UI_EXTERNAL_PORT=5183

# Monitoring (if used)
PROMETHEUS_EXTERNAL_PORT=9100
GRAFANA_EXTERNAL_PORT=3010
PGADMIN_EXTERNAL_PORT=5062
POSTGRES_EXPORTER_EXTERNAL_PORT=9198

# Splunk (if used)
SPLUNK_EXTERNAL_PORT=8099
SPLUNK_WEB_EXTERNAL_PORT=8012
SPLUNK_HEC_EXTERNAL_PORT=8098

# Echo Server (if used)
ECHO_SERVER_EXTERNAL_PORT=8013

# Vault
VAULT_EXTERNAL_PORT=8210

# LDAP (if used)
LDAP_EXTERNAL_PORT=1399
LDAPS_EXTERNAL_PORT=1646
