# Nightly CI environment — safe defaults for integration tests.
# No real secrets. Tracked in git. Used by nightly-integration.yml.
#
# This file is copied to .env at CI time so docker compose services
# (which use env_file: ../../.env) find it.

# ── PostgreSQL ──
POSTGRES_USER=dev
POSTGRES_PASSWORD=devpassword
POSTGRES_DB=analysi_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_EXTERNAL_PORT=5434
POSTGRES_HOST_AUTH_METHOD=md5

# ── Valkey ──
VALKEY_HOST=valkey
VALKEY_PORT=6379
VALKEY_PASSWORD=nightly-valkey-password
VALKEY_EXTERNAL_PORT=6380
REDIS_HOST=valkey
REDIS_PORT=6379
REDIS_DB=0

# ── MinIO ──
MINIO_ROOT_USER=nightly-minio-user
MINIO_ROOT_PASSWORD=nightly-minio-password
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=nightly-minio-user
MINIO_SECRET_KEY=nightly-minio-password
MINIO_BUCKET=analysi-storage
MINIO_EXTERNAL_PORT=9000
MINIO_CONSOLE_EXTERNAL_PORT=9001
ARTIFACTS_BUCKET=analysi-storage

# ── API keys — intentionally empty to prevent real LLM calls ──
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
