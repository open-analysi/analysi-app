# Copy to terraform.tfvars and fill in values.
# terraform.tfvars is gitignored — never commit secrets.

aws_region         = "us-east-1"
node_instance_type = "t3.large"
node_desired_size  = 2

# Image version: "latest" for most recent, or "sha-<commit>" for a specific build
# image_tag = "sha-abc1234"

# Restrict EKS API and ALB access to your IP (find yours: curl ifconfig.me)
# IMPORTANT: Set this to your IP for demo/testing — it restricts both
# the Kubernetes API and the ALB (HTTP traffic).
# public_access_cidrs = ["203.0.113.42/32"]

# Optional: ACM certificate ARN for ALB HTTPS (upgrades from HTTP to HTTPS)
# Without this, ALB serves HTTP — acceptable for short-lived demos with CIDR restriction.
# acm_certificate_arn = "arn:aws:acm:us-east-1:123456789:certificate/abc-123"

# GitHub PAT with read:packages scope (for pulling private GHCR images)
# Generate at: https://github.com/settings/tokens → read:packages
# Tip: prefer setting the PAT via `export TF_VAR_ghcr_pat=...` to keep it out of files.
ghcr_pat      = ""
ghcr_username = ""
