{
  "id": "crowdstrike",
  "app": "crowdstrike",
  "name": "CrowdStrike Falcon",
  "version": "1.0.0",
  "description": "CrowdStrike Falcon EDR/XDR platform integration for endpoint security, threat hunting, and incident response",
  "archetypes": [
    "EDR",
    "Sandbox",
    "ThreatIntel",
    "AlertSource"
  ],
  "priority": 70,
  "credential_schema": {
    "type": "object",
    "properties": {
      "client_id": {
        "type": "string",
        "display_name": "Client ID",
        "description": "OAuth2 Client ID",
        "required": true
      },
      "client_secret": {
        "type": "string",
        "display_name": "Client Secret",
        "description": "OAuth2 Client Secret",
        "format": "password",
        "required": true
      }
    }
  },
  "settings_schema": {
    "type": "object",
    "properties": {
      "base_url": {
        "type": "string",
        "display_name": "Base URL",
        "description": "CrowdStrike API base URL",
        "default": "https://api.crowdstrike.com",
        "placeholder": "https://api.crowdstrike.com",
        "required": true
      },
      "timeout": {
        "type": "integer",
        "display_name": "Request Timeout",
        "description": "HTTP request timeout in seconds",
        "default": 30,
        "minimum": 5,
        "maximum": 300
      },
      "default_lookback_minutes": {
        "type": "integer",
        "display_name": "Default Lookback (minutes)",
        "description": "How far back to search when no checkpoint exists",
        "default": 5,
        "minimum": 1
      }
    }
  },
  "archetype_mappings": {
    "EDR": {
      "isolate_host": "quarantine_device",
      "release_host": "unquarantine_device",
      "scan_host": "query_device",
      "get_host_details": "get_device_details",
      "kill_process": "run_command",
      "collect_forensics": "get_session_file",
      "run_script": "run_command"
    },
    "Sandbox": {
      "submit_file": "detonate_file",
      "submit_url": "detonate_url",
      "get_analysis_status": "check_detonation_status",
      "get_analysis_report": "check_detonation_status"
    },
    "ThreatIntel": {
      "lookup_file_hash": "file_reputation",
      "lookup_url": "url_reputation",
      "submit_ioc": "upload_indicator"
    },
    "AlertSource": {
      "pull_alerts": "pull_alerts",
      "alerts_to_ocsf": "alerts_to_ocsf"
    }
  },
