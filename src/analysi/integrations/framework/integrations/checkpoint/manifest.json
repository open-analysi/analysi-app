{
  "id": "checkpoint",
  "app": "checkpoint",
  "name": "Check Point Firewall",
  "version": "1.0.0",
  "description": "Check Point Firewall integration for IP containment, host/network management, and firewall policy operations via the Check Point Management API",
  "archetypes": [
    "NetworkSecurity"
  ],
  "priority": 75,
  "requires_credentials": true,

  "integration_id_config": {
    "default": "checkpoint-main",
    "pattern": "^[a-z0-9][a-z0-9-]*$",
    "placeholder": "checkpoint-main",
    "display_name": "Integration ID",
    "description": "Unique identifier for this Check Point instance"
  },

  "archetype_mappings": {
    "NetworkSecurity": {
      "block_ip": "block_ip",
      "unblock_ip": "unblock_ip"
    }
  },

  "credential_schema": {
    "type": "object",
    "properties": {
      "username": {
        "type": "string",
        "display_name": "Username",
        "description": "Check Point Management API username",
        "required": true
      },
      "password": {
        "type": "string",
        "display_name": "Password",
        "description": "Check Point Management API password",
        "format": "password",
        "required": true
      }
    }
  },

  "settings_schema": {
    "type": "object",
    "properties": {
      "url": {
        "type": "string",
        "display_name": "Management Server URL",
        "description": "Check Point Management Server URL with port (e.g. https://10.10.10.10:443)",
        "placeholder": "https://10.10.10.10:443",
        "required": true
      },
      "domain": {
        "type": "string",
        "display_name": "Domain",
        "description": "Check Point management domain (optional, for multi-domain environments)",
        "required": false
      },
      "verify_server_cert": {
        "type": "boolean",
        "display_name": "Verify Server Certificate",
        "description": "Verify SSL certificate when connecting to Check Point",
        "default": false,
        "required": false
      },
      "timeout": {
        "type": "integer",
        "display_name": "Request Timeout",
        "description": "HTTP request timeout in seconds",
        "default": 60
      }
    }
  },

  "actions": [
    {
      "id": "health_check",
      "name": "Health Check",
      "description": "Test connectivity to the Check Point Management Server by logging in and verifying the session",
      "categories": ["health_monitoring"],
      "cy_name": "health_check",
      "enabled": true,
      "params_schema": {
        "type": "object",
        "properties": {},
        "required": []
      }
    },
    {
      "id": "block_ip",
      "name": "Block IP",
      "description": "Block an IP/subnet by creating a host/network object and a Drop access rule in the specified layer. Supports simple IP, CIDR notation, and IP with subnet mask.",
      "categories": ["containment", "remediation"],
      "cy_name": "block_ip",
      "enabled": true,
      "params_schema": {
        "type": "object",
        "properties": {
          "ip": {
            "type": "string",
            "description": "IP address to block (supports IP, CIDR, IP + subnet mask)"
          },
          "policy": {
            "type": "string",
            "description": "Policy package name to install after blocking"
          },
          "layer": {
            "type": "string",
            "description": "Access layer name to add the drop rule to"
          },
          "skip_install_policy": {
            "type": "boolean",
            "description": "Skip the policy installation step after blocking",
            "default": false
          },
          "object_name": {
            "type": "string",
            "description": "Custom object name to use for an existing network object (optional)"
          }
        },
        "required": ["ip", "policy", "layer"]
      }
    },
    {
      "id": "unblock_ip",
      "name": "Unblock IP",
      "description": "Unblock an IP/subnet by deleting the corresponding Drop access rule from the specified layer",
      "categories": ["remediation"],
      "cy_name": "unblock_ip",
      "enabled": true,
      "params_schema": {
        "type": "object",
        "properties": {
          "ip": {
            "type": "string",
            "description": "IP address to unblock"
          },
          "policy": {
            "type": "string",
            "description": "Policy package name to install after unblocking"
          },
          "layer": {
            "type": "string",
            "description": "Access layer name containing the rule"
          }
        },
        "required": ["ip", "policy", "layer"]
      }
    },
    {
      "id": "list_policies",
      "name": "List Policies",
      "description": "List security policy packages configured on Check Point",
      "categories": ["investigation"],
      "cy_name": "list_policies",
      "enabled": true,
      "params_schema": {
        "type": "object",
        "properties": {},
        "required": []
      }
    },
    {
      "id": "list_layers",
      "name": "List Layers",
      "description": "List access layers configured on Check Point",
      "categories": ["investigation"],
      "cy_name": "list_layers",
      "enabled": true,
      "params_schema": {
        "type": "object",
        "properties": {},
        "required": []
      }
    },
    {
      "id": "list_hosts",
      "name": "List Hosts",
      "description": "List host objects configured on Check Point",
      "categories": ["investigation"],
      "cy_name": "list_hosts",
      "enabled": true,
      "params_schema": {
        "type": "object",
        "properties": {},
        "required": []
      }
    },
    {
      "id": "add_host",
      "name": "Add Host",
      "description": "Add a host object to Check Point. Supports IPv4 and/or IPv6 addresses.",
      "categories": ["configuration"],
      "cy_name": "add_host",
      "enabled": true,
      "params_schema": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Object/host name (must be unique in the domain)"
          },
          "ip": {
            "type": "string",
            "description": "IPv4 or IPv6 address"
          },
          "ipv4": {
            "type": "string",
            "description": "IPv4 address (use when both IPv4 and IPv6 are needed)"
          },
          "ipv6": {
            "type": "string",
            "description": "IPv6 address (use when both IPv4 and IPv6 are needed)"
          },
          "comments": {
            "type": "string",
            "description": "Comments to add to the host object"
          },
          "groups": {
            "type": "string",
            "description": "Comma-separated list of group identifiers"
          }
        },
        "required": ["name"]
      }
    },
    {
      "id": "delete_host",
      "name": "Delete Host",
      "description": "Delete a host object from Check Point. Specify either uid or name.",
      "categories": ["configuration"],
      "cy_name": "delete_host",
      "enabled": true,
      "params_schema": {
        "type": "object",
        "properties": {
          "uid": {
            "type": "string",
            "description": "Host unique identifier"
          },
          "name": {
            "type": "string",
            "description": "Host object name"
          }
        },
        "required": []
      }
    },
    {
      "id": "add_network",
      "name": "Add Network",
      "description": "Add a network object to Check Point with subnet and mask",
      "categories": ["configuration"],
      "cy_name": "add_network",
      "enabled": true,
      "params_schema": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Network object name (must be unique)"
          },
          "subnet": {
            "type": "string",
            "description": "IPv4 or IPv6 subnet address"
          },
          "subnet_v4": {
            "type": "string",
            "description": "IPv4 subnet address"
          },
          "subnet_v6": {
            "type": "string",
            "description": "IPv6 subnet address"
          },
          "subnet_mask_length": {
            "type": "integer",
            "description": "Subnet mask length"
          },
          "subnet_mask_length_v4": {
            "type": "integer",
            "description": "IPv4 subnet mask length"
          },
          "subnet_mask_length_v6": {
            "type": "integer",
            "description": "IPv6 subnet mask length"
          },
          "subnet_mask": {
            "type": "string",
            "description": "Dotted-decimal subnet mask"
          },
          "comments": {
            "type": "string",
            "description": "Comments to add to the network object"
          },
          "groups": {
            "type": "string",
            "description": "Comma-separated list of group identifiers"
          }
        },
        "required": ["name"]
      }
    },
    {
      "id": "delete_network",
      "name": "Delete Network",
      "description": "Delete a network object from Check Point. Specify either uid or name.",
      "categories": ["configuration"],
      "cy_name": "delete_network",
      "enabled": true,
      "params_schema": {
        "type": "object",
        "properties": {
          "uid": {
            "type": "string",
            "description": "Network unique identifier"
          },
          "name": {
            "type": "string",
            "description": "Network object name"
          }
        },
        "required": []
      }
    },
    {
      "id": "update_group_members",
      "name": "Update Group Members",
      "description": "Add, remove, or set members of a group on Check Point",
      "categories": ["configuration"],
      "cy_name": "update_group_members",
      "enabled": true,
      "params_schema": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Group name"
          },
          "uid": {
            "type": "string",
            "description": "Group unique identifier"
          },
          "members": {
            "type": "string",
            "description": "Comma-separated list of member names"
          },
          "action": {
            "type": "string",
            "description": "Action to perform: add, remove, or set",
            "enum": ["add", "remove", "set"]
          }
        },
        "required": ["members", "action"]
      }
    },
    {
      "id": "install_policy",
      "name": "Install Policy",
      "description": "Install a policy package to target gateways on Check Point",
      "categories": ["configuration"],
      "cy_name": "install_policy",
      "enabled": true,
      "params_schema": {
        "type": "object",
        "properties": {
          "policy": {
            "type": "string",
            "description": "Policy package name"
          },
          "targets": {
            "type": "string",
            "description": "Comma-separated list of target gateway names"
          },
          "access": {
            "type": "boolean",
            "description": "Whether to install the access policy"
          }
        },
        "required": ["policy", "targets"]
      }
    },
    {
      "id": "add_user",
      "name": "Add User",
      "description": "Create a user on Check Point using a template",
      "categories": ["configuration"],
      "cy_name": "add_user",
      "enabled": true,
      "params_schema": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "User name"
          },
          "template": {
            "type": "string",
            "description": "User template name"
          },
          "email": {
            "type": "string",
            "description": "User email address"
          },
          "phone_number": {
            "type": "string",
            "description": "User phone number"
          },
          "comments": {
            "type": "string",
            "description": "Comments to add to the user"
          }
        },
        "required": ["name", "template"]
      }
    },
    {
      "id": "delete_user",
      "name": "Delete User",
      "description": "Delete a user from Check Point. Specify either uid or name.",
      "categories": ["configuration"],
      "cy_name": "delete_user",
      "enabled": true,
      "params_schema": {
        "type": "object",
        "properties": {
          "uid": {
            "type": "string",
            "description": "User unique identifier"
          },
          "name": {
            "type": "string",
            "description": "User name"
          }
        },
        "required": []
      }
    },
    {
      "id": "logout_session",
      "name": "Logout Session",
      "description": "Logout a specific session or the current session on Check Point",
      "categories": ["configuration"],
      "cy_name": "logout_session",
      "enabled": true,
      "params_schema": {
        "type": "object",
        "properties": {
          "session_id": {
            "type": "string",
            "description": "Session ID to logout (defaults to current session if not specified)"
          }
        },
        "required": []
      }
    }
  ],

  "default_schedules": [
    {
      "action_id": "health_check",
      "schedule": "every/5m",
      "enabled": true
    }
  ]
}
