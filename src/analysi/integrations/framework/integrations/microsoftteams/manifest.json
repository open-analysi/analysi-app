          },
          "message": {
            "type": "string",
            "description": "Message to send (supports HTML)"
          }
        },
        "required": [
          "user_id",
          "message"
        ]
      }
    },
    {
      "id": "create_meeting",
      "name": "Create Meeting",
      "description": "Create an online meeting in Microsoft Teams",
      "categories": [
        "generic"
      ],
      "cy_name": "create_meeting",
      "params_schema": {
        "type": "object",
        "properties": {
          "subject": {
            "type": "string",
            "description": "Meeting subject"
          },
          "add_calendar_event": {
            "type": "boolean",
            "description": "Add meeting to calendar (default: false)"
          },
          "description": {
            "type": "string",
            "description": "Meeting description (only used if add_calendar_event is true)"
          },
          "start_time": {
            "type": "string",
            "description": "Start time in ISO 8601 format (only used if add_calendar_event is true)"
          },
          "end_time": {
            "type": "string",
            "description": "End time in ISO 8601 format (only used if add_calendar_event is true)"
          },
          "attendees": {
            "type": "string",
            "description": "Comma-separated email addresses of attendees (only used if add_calendar_event is true)"
          }
        },
        "required": []
