{
  "id": "microsoftteams",
  "app": "microsoftteams",
  "name": "Microsoft Teams",
  "version": "1.0.0",
  "description": "Integrate with Microsoft Teams to send messages, manage channels, create meetings, and collaborate with teams",
  "archetypes": [
    "Communication"
  ],
  "priority": 55,
  "credential_schema": {
    "type": "object",
    "properties": {
      "client_id": {
        "type": "string",
        "description": "Application (client) ID from Azure AD app registration"
      },
      "client_secret": {
        "type": "string",
        "description": "Client secret from Azure AD app registration",
        "format": "password"
      },
      "access_token": {
        "type": "string",
        "description": "Microsoft Graph API access token (obtained via OAuth 2.0)",
        "format": "password"
      }
    },
    "required": [
      "client_id",
      "client_secret",
      "access_token"
    ]
  },
  "settings_schema": {
    "type": "object",
    "properties": {
      "tenant_id": {
        "type": "string",
        "description": "Azure AD Tenant ID"
      },
      "timeout": {
        "type": "integer",
        "description": "Request timeout in seconds",
        "default": 30
      },
      "timezone": {
        "type": "string",
        "description": "Timezone for calendar events (e.g., 'UTC', 'America/New_York')",
        "default": "UTC"
      }
    },
    "required": []
  },
