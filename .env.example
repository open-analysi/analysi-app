# Environment Configuration
ENVIRONMENT=development
PORT=8000
LOG_LEVEL=DEBUG

# Database Configuration
DATABASE_URL=postgresql+asyncpg://dev:devpassword@localhost:5434/analysi_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_ECHO=false

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Backend API Configuration (for internal service-to-service communication)
# Use Docker service names for cross-platform compatibility (works on Mac, Linux, EC2)
BACKEND_API_HOST=api
BACKEND_API_PORT=8000
BACKEND_API_EXTERNAL_PORT=8001
BACKEND_API_AUTH_TOKEN=
DEFAULT_TENANT=default

# MinIO Configuration for Artifacts (separate from general storage)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=
ARTIFACTS_BUCKET=analysi-storage-prod

# External Port Mappings
MINIO_EXTERNAL_PORT=9000
MINIO_CONSOLE_EXTERNAL_PORT=9001

# Monitoring Stack Ports
PROMETHEUS_EXTERNAL_PORT=9090
GRAFANA_EXTERNAL_PORT=3000
POSTGRES_EXPORTER_EXTERNAL_PORT=9188
VALKEY_EXPORTER_EXTERNAL_PORT=9121
NODE_EXPORTER_PORT=9100           # Running on host machine
THERMAL_EXPORTER_PORT=9101         # macOS thermal metrics (host machine)

# Vault Configuration
VAULT_HOST=vault
VAULT_PORT=8200
VAULT_EXTERNAL_PORT=8200
VAULT_DEV_ROOT_TOKEN=
VAULT_LOG_LEVEL=info
VAULT_TOKEN=

# Integration Worker Configuration
INTEGRATION_REDIS_HOST=valkey
INTEGRATION_REDIS_PORT=6379
INTEGRATION_REDIS_DB=1
INTEGRATION_DEFAULT_TENANT=default
INTEGRATION_POLL_INTERVAL=60
INTEGRATION_PULL_LOOKBACK=120
INTEGRATION_MAX_JOBS=10
INTEGRATION_JOB_TIMEOUT=300

# Integration Reconciliation Settings
INTEGRATION_RECONCILE_INTERVAL=300
INTEGRATION_RECONCILE_LOCK_TTL=30

# Third-Party Integration API Keys for Testing
# REQUIRED for integration tests - tests will FAIL if not provided
# Get free API keys from the respective services:
# - AbuseIPDB: https://www.abuseipdb.com/ (1,000 requests/day free) - REQUIRED
# - VirusTotal: https://www.virustotal.com/ (500 requests/day free) - Optional
ABUSEIPDB_API_KEY=
VIRUSTOTAL_API_KEY=

# Agentic Orchestration Configuration
# Runtime configuration for alert processing agents
ANALYSI_ALERT_PROCESSING_AGENT_DIR=  # Optional: Override agent directory for testing

# Build/Packaging Configuration
# Agent/skill packaging now uses skilltree.yaml as source of truth.
# Run: make package-agents / make package-skills

# Keycloak Configuration (Mikonos Phase 5)
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=
KEYCLOAK_EXTERNAL_PORT=8080

# Auth Configuration (Mikonos Phase 5)
# Set ANALYSI_AUTH_JWKS_URI to enable JWT validation. Comment out to run without Keycloak.
# ANALYSI_AUTH_JWKS_URI=http://keycloak:8080/realms/analysi/protocol/openid-connect/certs
# ANALYSI_AUTH_ISSUER=http://keycloak:8080/realms/analysi
# ANALYSI_AUTH_AUDIENCE=analysi-app
ANALYSI_AUTH_MODE=dev

# System API Key — workers use this to authenticate API calls. Change in production.
ANALYSI_SYSTEM_API_KEY=

# Dev API Keys — provisioned on startup when ANALYSI_AUTH_MODE=dev
# Owner: full tenant control (CLI, demo-loader, admin tools)
ANALYSI_OWNER_API_KEY=
# Admin: admin role without owner bypass (for testing non-owner flows)
ANALYSI_ADMIN_API_KEY=
