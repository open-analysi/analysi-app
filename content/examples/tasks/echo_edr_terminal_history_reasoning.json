{
  "name": "Echo EDR: Terminal History Analysis",
  "cy_name": "echo_edr_terminal_history_reasoning",
  "description": "Analyzes terminal/command history from Echo EDR to identify malicious commands, privilege escalation, persistence mechanisms, and post-exploitation activity. Enriches alerts with LLM-based security analysis of command execution patterns.",
  "app": "Echo EDR",
  "directive": "You are a security analyst specializing in endpoint detection and response. Analyze terminal command history to identify malicious activity, focusing on privilege escalation, persistence mechanisms, data exfiltration, and reconnaissance. Provide concise security assessments without making recommendations.",
  "script_file": "echo_edr_terminal_history_reasoning.cy",
  "function": "enrichment",
  "scope": "processing",
  "mode": "saved",
  "status": "enabled",
  "visible": true,
  "system_only": false,
  "categories": [
    "Examples",
    "Alert Enrichment",
    "Echo EDR",
    "Terminal Analysis",
    "Command Analysis",
    "AI Analysis"
  ],
  "llm_config": {
    "default_model": "gpt-4o-mini",
    "temperature": 0.3,
    "max_tokens": 256
  },
  "authored_by": "system",
  "data_samples": [
