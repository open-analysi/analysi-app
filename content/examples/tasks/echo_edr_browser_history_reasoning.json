{
  "name": "Echo EDR: Browser History Analysis",
  "cy_name": "echo_edr_browser_history_reasoning",
  "description": "Enriches alerts with Echo EDR browser history analysis. Extracts IP address from alert (device, network_info, or IOC), retrieves browser activity data, performs AI-powered security analysis to identify suspicious web activity, IOCs, and compromise indicators. Adds structured enrichment data with risk scoring and recommended actions.",
  "app": "Echo EDR",
  "directive": "You are a cybersecurity analyst specializing in digital forensics and endpoint behavior analysis. Analyze browser history data from Echo EDR to identify suspicious web activity, potential compromise indicators, and security risks. Focus on detecting malicious domains, data exfiltration attempts, reconnaissance activity, and other threat indicators. Provide clear, actionable security assessments.",
  "script_file": "echo_edr_browser_history_reasoning.cy",
  "function": "reasoning",
  "scope": "processing",
  "mode": "saved",
  "status": "enabled",
  "visible": true,
  "system_only": false,
