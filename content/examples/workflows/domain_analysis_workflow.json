        "source_product": {
          "type": "string"
        },
        "source_category": {
          "type": "string"
        },
        "primary_ioc_type": {
          "type": "string"
        },
        "primary_ioc_value": {
          "type": "string"
        },
        "triggering_event_time": {
          "type": "string"
        },
        "primary_risk_entity_type": {
          "type": "string"
        },
        "primary_risk_entity_value": {
          "type": "string"
        }
      },
      "required": [
        "title",
        "severity",
        "raw_alert",
        "rule_name",
        "alert_type",
        "network_info",
        "device_action",
        "source_vendor",
        "source_product",
        "source_category",
        "primary_ioc_type",
        "primary_ioc_value",
        "triggering_event_time",
        "primary_risk_entity_type",
        "primary_risk_entity_value"
      ]
    },
    "output": {
      "type": "object"
    }
  },
