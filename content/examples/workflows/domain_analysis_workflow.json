      "$schema": "http://json-schema.org/schema#",
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "severity": {
          "type": "string"
        },
        "raw_alert": {
          "type": "string"
        },
        "rule_name": {
          "type": "string"
        },
        "alert_type": {
          "type": "string"
        },
        "network_info": {
          "type": "object",
