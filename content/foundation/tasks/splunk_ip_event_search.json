{
  "name": "Splunk: IP Event Search and Correlation",
  "cy_name": "splunk_ip_event_search",
  "description": "Enriches alerts by searching Splunk SIEM for security events related to the primary IOC IP address. Queries across all indexes for the last 24 hours, analyzes event patterns, and provides AI-powered correlation analysis linking events to the original alert.",
  "app": "Splunk",
  "directive": "You are a security analyst specializing in SIEM event correlation and analysis. Analyze Splunk search results to identify patterns, assess event volume and frequency, correlate findings with the original security alert, and provide actionable investigation guidance. Focus on timeline analysis, baseline deviation detection, and clear next steps for SOC analysts.",
  "script_file": "splunk_ip_event_search.cy",
  "function": "reasoning",
  "scope": "processing",
  "mode": "saved",
  "status": "enabled",
  "visible": true,
  "system_only": false,
  "categories": [
    "Foundation",
    "Splunk",
    "SIEM",
    "Event Correlation",
    "IP Analysis",
    "Alert Enrichment",
    "Investigation",
    "AI"
  ],
