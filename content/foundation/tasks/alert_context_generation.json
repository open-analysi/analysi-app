{
  "name": "Alert Context Generation",
  "cy_name": "alert_context_generation",
  "description": "Enriches alerts with concise, LLM-ready context summaries for downstream AI analysis and workflow composition. Generates structured context under enrichments['alert_context'] with completeness scoring and metadata.",
  "app": "default",
  "directive": "You are a security analyst creating concise alert summaries for AI-powered analysis. Extract the most critical information to create clear, actionable context that supports downstream investigation and decision-making.",
  "script_file": "alert_context_generation.cy",
  "function": "enrichment",
  "scope": "processing",
  "mode": "saved",
  "status": "enabled",
  "visible": true,
  "system_only": false,
  "categories": [
    "Foundation",
    "Alert Analysis",
    "Context Generation",
    "Alert Enrichment",
    "AI",
    "Workflow"
  ],
  "llm_config": {
    "default_model": "gpt-4o-mini",
    "temperature": 0.2,
    "max_tokens": 300
  },
  "authored_by": "system",
