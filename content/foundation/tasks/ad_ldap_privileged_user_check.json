{
  "name": "AD LDAP: Privileged User Group Membership Check",
  "cy_name": "ad_ldap_privileged_user_check",
  "description": "Enriches alerts with Active Directory group membership analysis to identify privileged users and assess security risk level. Critical for alert triage - users with elevated privileges (Domain Admins, Enterprise Admins, etc.) significantly increase threat severity and require immediate attention. Only processes alerts where the primary entity type is 'user' (via actor.user).",
  "app": "IdentityProvider",
  "directive": "You are a senior security analyst specializing in identity and access management. Analyze Active Directory group memberships to identify privileged users and assess security risk in the context of security alerts. Focus on: 1) Identifying highly privileged groups (Domain Admins, Enterprise Admins, Schema Admins), 2) Calculating risk scores based on privilege level, 3) Explaining how elevated privileges affect THIS SPECIFIC ALERT's severity and investigation priority, 4) Recommending specific monitoring and response actions for privileged user activities in the alert context.",
  "script_file": "ad_ldap_privileged_user_check.cy",
  "function": "reasoning",
  "scope": "processing",
  "mode": "saved",
  "status": "enabled",
  "visible": true,
  "system_only": false,
