{
  "name": "AD LDAP: Account Status and Risk Assessment",
  "cy_name": "ad_ldap_account_status_risk_assessment",
  "description": "Enriches alerts with Active Directory account status and risk assessment. Validates primary risk entity is a user, queries LDAP for account details (email, display name, group memberships), and provides AI-powered security analysis connecting account status to the alert context.",
